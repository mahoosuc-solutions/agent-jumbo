{
  "name": "Agent Jumbo Development",
  "build": {
    "dockerfile": "../DockerfileLocal",
    "context": "..",
    "args": {
      "BRANCH": "local"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "usernamehw.errorlens",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/root/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        }
      }
    }
  },
  "forwardPorts": [5000, 80, 22, 9000, 9001, 9002],
  "postCreateCommand": "bash -c 'source /root/.venv/bin/activate && playwright install chromium'",
  "remoteUser": "root",
  "mounts": [
    "source=${localWorkspaceFolder}/memory,target=/a0/memory,type=bind",
    "source=${localWorkspaceFolder}/knowledge,target=/a0/knowledge,type=bind",
    "source=${localWorkspaceFolder}/logs,target=/a0/logs,type=bind"
  ],
  "containerEnv": {
    "CODE_EXEC_SSH_ENABLED": "false",
    "PYTHONPATH": "/a0",
    "PATH": "/root/.venv/bin:${PATH}"
  },
  "remoteEnv": {
    "PATH": "/root/.venv/bin:${PATH}"
  }
}
