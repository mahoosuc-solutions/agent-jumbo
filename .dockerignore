###############################################################################
# Docker runtime artifacts - MUST BE EXCLUDED TO PREVENT PERMISSION ERRORS
###############################################################################
docker/run/
docker/run/**
!docker/run/fs/
!docker/run/fs/**

###############################################################################
# Project‑specific exclusions / re‑includes
###############################################################################

# Large / generated data
memory/**
ollama_models/**
*.gguf
*.bin

# Logs, tmp, usr
logs/*
tmp/*
usr/*

# Build outputs / generated artifacts
scripts/training/output/**
docs/diagrams/generated/**
.buildx-cache/**
dist/**
build/**

# Knowledge directory – keep only default/
knowledge/**
!knowledge/default/
!knowledge/default/**

# Instruments directory – keep default/ and all custom instrument source files
# (data/ dirs with SQLite DBs are excluded by the **/*.py[cod] rules below)
instruments/**
!instruments/__init__.py
!instruments/default/
!instruments/default/**
!instruments/custom/
!instruments/custom/__init__.py
!instruments/custom/**/
!instruments/custom/**/*.py

# Keep .gitkeep markers anywhere
!**/.gitkeep


###############################################################################
# Environment / tooling
###############################################################################
.conda/
.cursor/
.venv/
.git/
.worktrees/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
**/node_modules/
**/.next/
**/dist/
**/build/

# Keep dependency manifests and optional lock/wheelhouse metadata.
!requirements.txt
!requirements2.txt
!requirements.lock.txt
!pyproject.toml
!docker/wheelhouse/
!docker/wheelhouse/**


###############################################################################
# Tests (root‑level only)
###############################################################################
/*.test.py


###############################################################################
# ─── LAST SECTION: universal junk / caches (MUST BE LAST) ───
#   Put these at the *bottom* so they override any ! re‑includes above
###############################################################################
# OS / editor junk
**/.DS_Store
**/Thumbs.db

# Python caches / compiled artefacts
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd

# Environment files anywhere
*.env
