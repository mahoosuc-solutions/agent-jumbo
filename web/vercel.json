{
  "version": 2,
  "name": "agent-mahoo",
  "public": true,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "required": true
    },
    "NEXT_PUBLIC_GITHUB_REPO": {
      "required": true
    },
    "NEXT_PUBLIC_GA_ID": {
      "required": false
    },
    "NEXT_PUBLIC_URL": {
      "required": true
    },
    "NEXT_PUBLIC_ENABLE_BETA_FEATURES": {
      "required": false
    }
  },
  "github": {
    "enabled": true,
    "silent": false,
    "autoAlias": true,
    "autoJobCancelOnPush": true
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs",
      "destination": "/documentation",
      "permanent": true
    }
  ]
}
