# Agent Jumbo Environment Configuration Template
# Copy this file to .env.local and fill in your actual values
# This file is safe to commit - it contains no secrets

# ============================================================================
# API Configuration
# ============================================================================
# The base URL for your API endpoints
# Development: http://localhost:3000/api or http://localhost:8000
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# GitHub Configuration
# ============================================================================
# GitHub repository for stats and information
# Format: owner/repo (e.g., agent-jumbo-deploy/agent-jumbo)
NEXT_PUBLIC_GITHUB_REPO=agent-jumbo-deploy/agent-jumbo

# GitHub personal access token (optional, needed for private repos or higher rate limits)
# Generate at: https://github.com/settings/tokens
# Scopes needed: repo (for private repos), public_repo (for public repos)
# NOTE: This should be kept private - only set in .env.local, never commit to version control
NEXT_PUBLIC_GITHUB_TOKEN=your_github_token_here

# ============================================================================
# Google Analytics
# ============================================================================
# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Get your ID from: https://analytics.google.com
# Leave empty to disable analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================================================
# Deployment Configuration
# ============================================================================
# The public URL where your application will be deployed
# Development: http://localhost:3000
# Production: https://your-domain.com or https://your-project.vercel.app
NEXT_PUBLIC_URL=http://localhost:3000

# ============================================================================
# Feature Flags
# ============================================================================
# Enable beta features and experimental functionality
# Set to true to enable, false to disable
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# ============================================================================
# Optional: Logging Configuration
# ============================================================================
# Set to 'development' or 'production'
NODE_ENV=development

# ============================================================================
# Notes
# ============================================================================
# NEXT_PUBLIC_* variables are exposed to the browser - never put secrets here
# Secret variables (API keys, tokens) should NOT have NEXT_PUBLIC_ prefix
# In Vercel, secret variables are set in project settings, not in code
#
# For local development:
#   1. Copy this file: cp .env.example .env.local
#   2. Edit .env.local with your actual values
#   3. Never commit .env.local to version control
#
# For Vercel deployment:
#   1. Set environment variables in Vercel Dashboard
#   2. Go to Project Settings > Environment Variables
#   3. Add each variable with its value
#   4. Redeploy for changes to take effect
