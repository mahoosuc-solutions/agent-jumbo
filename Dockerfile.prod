# Production Dockerfile for Agent Jumbo
#
# Two-stage layer strategy:
#   deps  — apt packages, pip installs, playwright, preload (slow; cached unless requirements change)
#   app   — project source copy + post-install wiring (fast; rebuilds on every code change)
#
# First build after this change is full-length. Subsequent code-only rebuilds skip all deps.

ARG BASE_IMAGE=agent0ai/agent-zero-base@sha256:342ffbf59b5d2771c01f348cb9ee3e05121ad7a639aa5bff5c48c2912685eda8
FROM ${BASE_IMAGE} AS deps

ARG INSTALL_PLAYWRIGHT=1
ARG RUN_PRELOAD=1
ARG INSTALL_ADDITIONAL_TOOLS=1
ARG INSTALL_MERMAID_CLI=0
ENV INSTALL_PLAYWRIGHT=$INSTALL_PLAYWRIGHT
ENV RUN_PRELOAD=$RUN_PRELOAD
ENV INSTALL_ADDITIONAL_TOOLS=$INSTALL_ADDITIONAL_TOOLS
ENV INSTALL_MERMAID_CLI=$INSTALL_MERMAID_CLI

# Override apt mirror: http.kali.org is unreachable from some build environments
# (including WSL2 NAT). Use the kali.download CDN which is always available.
RUN echo "deb https://kali.download/kali kali-rolling main contrib non-free non-free-firmware" \
    > /etc/apt/sources.list && \
    apt-get update -qq

# Copy AJ-specific install scripts and configs
COPY ./docker/run/fs/ /

# Pre-installation steps (apt packages, system config)
RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt \
    bash /ins/pre_install.sh local

# Copy ONLY the dependency manifests — not the full source.
# This layer only invalidates when requirements actually change.
RUN mkdir -p /git/agent-jumbo
COPY requirements.txt requirements2.txt /git/agent-jumbo/

# Refresh apt index (base image may be stale vs Kali rolling repos)
RUN apt-get update

# Install Python dependencies
RUN --mount=type=cache,target=/root/.cache/pip \
    --mount=type=cache,target=/root/.cache/uv \
    bash -c '. /ins/setup_venv.sh local && \
    uv pip install -r /git/agent-jumbo/requirements.txt && \
    uv pip install -r /git/agent-jumbo/requirements2.txt'

# Install playwright browsers into a stable path (not inside /aj which is copied later)
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright
RUN bash -c 'if [ "${INSTALL_PLAYWRIGHT:-1}" = "1" ]; then \
        . /ins/setup_venv.sh local && \
        uv pip install playwright && \
        apt-get install -y fonts-unifont libnss3 libnspr4 libatk1.0-0 libatspi2.0-0 \
            libxcomposite1 libxdamage1 libatk-bridge2.0-0 libcups2 && \
        playwright install chromium --only-shell; \
    else \
        echo "Skipping Playwright install (INSTALL_PLAYWRIGHT=${INSTALL_PLAYWRIGHT})"; \
    fi'

# Install additional tools (runs against the deps layer, cached separately)
RUN bash /ins/install_additional.sh local

# App stage — only this layer rebuilds on code changes
FROM deps AS app

# Copy full project source
COPY . /git/agent-jumbo
COPY . /aj
WORKDIR /aj

# usr/projects is excluded from the image (large user data) but lives on the host
# bind-mounted at /mnt/wdblack (local) or as an empty dir (cloud).
RUN if [ -d "/mnt/wdblack/dev/projects/agent-jumbo/usr/projects" ]; then \
        ln -sf /mnt/wdblack/dev/projects/agent-jumbo/usr/projects /aj/usr/projects; \
    else \
        mkdir -p /aj/usr/projects; \
    fi

# Preload models (runs after source is present; skip with RUN_PRELOAD=0 for fast iteration)
RUN bash -c 'if [ "${RUN_PRELOAD:-1}" = "1" ]; then \
        . /ins/setup_venv.sh local && \
        python /git/agent-jumbo/preload.py --dockerized=true; \
    else \
        echo "Skipping preload (RUN_PRELOAD=${RUN_PRELOAD})"; \
    fi'

# Cleanup package lists
RUN rm -rf /var/lib/apt/lists/* && apt-get clean

EXPOSE 22 80 9000-9009

RUN chmod +x /exe/initialize.sh /exe/run_aj.sh /exe/run_searxng.sh /exe/run_tunnel_api.sh

HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=3 \
    CMD curl -fsS http://localhost:80/health | python3 -c "import sys,json; d=json.load(sys.stdin); sys.exit(0 if d.get('ok') else 1)" || exit 1

CMD ["/exe/initialize.sh", "production"]
