# Production Dockerfile for Agent Jumbo
# Bakes the entire codebase into the image at build time.
# Only data volumes and external drive mounts are used at runtime.
ARG BASE_IMAGE=agent0ai/agent-zero-base:latest
FROM ${BASE_IMAGE}

ARG INSTALL_PLAYWRIGHT=1
ARG RUN_PRELOAD=1
ARG INSTALL_ADDITIONAL_TOOLS=1
ENV INSTALL_PLAYWRIGHT=$INSTALL_PLAYWRIGHT
ENV RUN_PRELOAD=$RUN_PRELOAD
ENV INSTALL_ADDITIONAL_TOOLS=$INSTALL_ADDITIONAL_TOOLS

# Override apt mirror: http.kali.org is unreachable from some build environments
# (including WSL2 NAT). Use the kali.download CDN which is always available.
RUN echo "deb https://kali.download/kali kali-rolling main contrib non-free non-free-firmware" \
    > /etc/apt/sources.list && \
    apt-get update -qq

# Copy AJ-specific install scripts and configs
COPY ./docker/run/fs/ /

# pre installation steps (apt packages, system config)
RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt \
    bash /ins/pre_install.sh local

# Copy full project into /git/agent-jumbo (matches expected install path)
# and also into /aj (runtime working directory)
COPY . /git/agent-jumbo
COPY . /aj
WORKDIR /aj

# Refresh apt index (base image may be stale vs Kali rolling repos)
RUN apt-get update

# Install AJ dependencies using local copy (no GitHub clone needed)
RUN --mount=type=cache,target=/root/.cache/pip \
    --mount=type=cache,target=/root/.cache/uv \
    bash /ins/install_aj.sh local

# Install additional software (playwright, etc.)
RUN bash /ins/install_additional.sh local

# Post-install cleanup and config (local mode skips git clone in install_aj2.sh)
RUN bash /ins/install_aj2.sh local
RUN bash /ins/post_install.sh local

EXPOSE 22 80 9000-9009

RUN chmod +x /exe/initialize.sh /exe/run_aj.sh /exe/run_searxng.sh /exe/run_tunnel_api.sh

CMD ["/exe/initialize.sh", "production"]
