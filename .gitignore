# Ignore common unwanted files globally
**/.DS_Store
**/.env
**/__pycache__/
*.py[cod]
**/.conda/

#Ignore IDE files
.cursor/
.windsurf/
.superpowers/

# ignore test files in root dir
/*.test.py

# Ignore all contents of the virtual environment directory
.venv/

# Handle memory directory
memory/**
!memory/**/

# Handle logs directory
logs/*

# Handle tmp and usr directory
tmp/*
usr/*

# Handle knowledge directory
knowledge/**
!knowledge/**/
# Explicitly allow the default and custom folders in knowledge
!knowledge/default/
!knowledge/default/**
!knowledge/custom/
!knowledge/custom/**
!knowledge/INTERNAL_KNOWLEDGE_MAP.md

# Handle instruments directory
instruments/**
!instruments/**/
# Allow package init files at the instruments root and custom level
!instruments/__init__.py
!instruments/custom/__init__.py
# Explicitly allow the default folder in instruments
!instruments/default/
!instruments/default/**
!instruments/custom/
!instruments/custom/google_voice/
!instruments/custom/google_voice/**
!instruments/custom/twilio_voice/
!instruments/custom/twilio_voice/**
# Track all custom instrument Python source files
!instruments/custom/**/
!instruments/custom/**/*.py
# Keep Python cache files ignored under custom instruments.
instruments/custom/**/__pycache__/
instruments/custom/**/__pycache__/**
# Keep data directories ignored (SQLite DBs, uploads, etc.)
instruments/custom/**/data/

# Global rule to include .gitkeep files anywhere
!**/.gitkeep

# for browser-use
agent_history.gif

# Git worktrees directory
.worktrees/

# WireGuard config (contains private keys)
wireguard/

# Ollama Models - Stored in GCP Bucket
# Download with: ./scripts/gcp_models_sync.sh download
ollama_models/models/
ollama_models/blobs/
!ollama_models/model_manifest.json
!ollama_models/README.md
!ollama_models/.gitkeep

# Sensitive files - never commit
.env.local
.env.*.local
.env.production
*.key
*.pem
secrets/
credentials/

# Additional IDE files
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Python packaging and distribution
*.egg-info/
dist/
build/
*.egg

# Test coverage reports
.coverage
htmlcov/
.pytest_cache/
*.cover

# Node/npm (if WebUI development)
npm-debug.log
yarn-error.log

# OS-specific files
Thumbs.db
*.log

# Local development database files
*.db
*.sqlite
*.sqlite3

# Firebase debug logs
firebase-debug.log

# Temporary files
*.tmp
*.temp
.tmp/
web/.next/
packages/
node_modules/

# Local build cache and generated training artifacts
.buildx-cache/
scripts/training/output/

# Docker runtime artifacts (generated when running Docker containers)

# Local MCP server wiring (contains ephemeral tokenized URLs)
.mcp.json

# Runtime data directories
data/llm_router.db
data/chats/
data/scheduler/
docker/run-bak-*
docker/run-old-*

# E2E test screenshots (generated on failure)
tests/e2e/screenshots/

# Git worktrees
.worktrees/
data/identity.db
