# ============================================
# Agent Jumbo Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Lines starting with # are comments

# ============================================
# MODEL CONFIGURATION
# ============================================
# Provider: openai, anthropic, google, azure, ollama, lm_studio, openrouter, groq, other
# CHAT_MODEL_PROVIDER=openai
# CHAT_MODEL_NAME=gpt-4o
# CHAT_MODEL_API_BASE=              # Leave empty for default. Set for Azure, Ollama, LM Studio
# CHAT_MODEL_CTX_LENGTH=128000      # Context window size in tokens
# CHAT_MODEL_VISION=true            # Enable vision capabilities

# Utility model (for summarization, extraction, etc.)
# UTIL_MODEL_PROVIDER=openai
# UTIL_MODEL_NAME=gpt-4o-mini
# UTIL_MODEL_API_BASE=
# UTIL_MODEL_CTX_LENGTH=128000

# Embedding model (for memory/knowledge)
# EMBED_MODEL_PROVIDER=openai
# EMBED_MODEL_NAME=text-embedding-3-small
# EMBED_MODEL_API_BASE=

# Browser model (for web browsing agent)
# BROWSER_MODEL_PROVIDER=openai
# BROWSER_MODEL_NAME=gpt-4o
# BROWSER_MODEL_VISION=true

# ============================================
# API KEYS
# ============================================
# Set the API keys for providers you use
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://YOUR_RESOURCE.openai.azure.com/
# AZURE_API_VERSION=2024-02-15-preview
# OPENROUTER_API_KEY=...
# GROQ_API_KEY=...

# ============================================
# ANTHROPIC ADVANCED FEATURES
# ============================================
# Prompt Caching (90% cost reduction, 85% latency improvement)
# ANTHROPIC_ENABLE_CACHING=true
# ANTHROPIC_CACHE_TTL_SECONDS=3600         # 1 hour for extended thinking, 300 for default

# Model Selection
# ANTHROPIC_OPUS_4_5_ENABLED=true
# ANTHROPIC_EFFORT_LEVEL=medium            # low, medium, high - controls token usage

# Batch API (50% cost discount for non-urgent tasks)
# ANTHROPIC_BATCH_ENABLED=true
# ANTHROPIC_BATCH_POLL_INTERVAL=300        # 5 minutes

# Advanced Features
# USE_NATIVE_ANTHROPIC_SDK=false           # Use LiteLLM by default, enable for advanced features
# ANTHROPIC_TOOL_SEARCH_ENABLED=true       # Dynamic tool discovery
# ANTHROPIC_PTC_ENABLED=true               # Programmatic Tool Calling (37% token reduction)

# For Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434

# For LM Studio (local)
# LM_STUDIO_BASE_URL=http://localhost:1234/v1

# ============================================
# WEB UI CONFIGURATION
# ============================================
WEB_UI_PORT=5000
# AGENT_JUMBO_RUN_MODE=local-lite    # full, local-lite, research
# AGENT_JUMBO_LAPTOP_MODE=true       # Legacy flag; local-lite if true
# AUTH_LOGIN=admin
# AUTH_PASSWORD=                    # Leave empty to disable auth

# ============================================
# DOCKER FILE OWNERSHIP
# ============================================
# UID/GID for files created inside Docker containers.
# Set these to your host user's UID/GID so that files written by the
# container (logs, databases, knowledge) are owned by your user on the
# host filesystem.  Run `id -u` and `id -g` to find your values.
# FILE_OWNER_UID=1000
# FILE_OWNER_GID=1000

# ============================================
# CODE EXECUTION (SSH/Docker)
# ============================================
# Enable SSH-based code execution to Docker container
CODE_EXEC_SSH_ENABLED=true
CODE_EXEC_SSH_ADDR=localhost
CODE_EXEC_SSH_PORT=55022
CODE_EXEC_SSH_USER=root
# CODE_EXEC_SSH_PASS=               # Usually empty for key-based auth

# ============================================
# REMOTE FUNCTION CALLING (RFC)
# ============================================
# Connect to external Docker runtime
# RFC_AUTO_DOCKER=true              # Auto-start Docker container
# RFC_URL=http://localhost:55080
# RFC_PASSWORD=
# RFC_PORT_HTTP=55080
# RFC_PORT_SSH=55022

# ============================================
# MEMORY & KNOWLEDGE
# ============================================
# MEMORY_RECALL_ENABLED=true
# MEMORY_RECALL_DELAYED=true        # Delay recall for better context
# MEMORY_MEMORIZE_ENABLED=true
# MEMORY_MEMORIZE_CONSOLIDATION=true

# Agent profile to use (folder name in /agents/)
# AGENT_PROFILE=digital-clone
# AGENT_MEMORY_SUBDIR=digital-clone # Subdirectory for memory isolation
# AGENT_KNOWLEDGE_SUBDIR=digital-clone # Subdirectory for knowledge base

# ============================================
# MCP (MODEL CONTEXT PROTOCOL)
# ============================================
# MCP_SERVERS={}                    # JSON config or leave for mcp_config_claude.json
# MCP_CLIENT_INIT_TIMEOUT=30
# MCP_CLIENT_TOOL_TIMEOUT=60
# MCP_SERVER_ENABLED=false          # Enable Agent Jumbo as MCP server
# MCP_SERVER_TOKEN=                 # Token for MCP server auth

# ============================================
# AGENT-TO-AGENT COMMUNICATION
# ============================================
# A2A_SERVER_ENABLED=false

# ============================================
# SPEECH (STT/TTS)
# ============================================
# STT_MODEL_SIZE=base               # tiny, base, small, medium, large
# STT_LANGUAGE=en
# STT_SILENCE_THRESHOLD=0.02
# STT_SILENCE_DURATION=500
# STT_WAITING_TIMEOUT=5000
# TTS_KOKORO=true                   # Use Kokoro TTS

# ============================================
# GMAIL INTEGRATION
# ============================================
# Requires OAuth setup - see docs/gmail-setup.md
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# ============================================
# COWORK MODE
# ============================================
# COWORK_ENABLED=false
# COWORK_REQUIRE_APPROVALS=true
# COWORK_ALLOWED_PATHS=/home/user/projects

# ============================================
# OBSERVABILITY
# ============================================
# OBSERVABILITY_PROVIDER=           # langsmith, langfuse, or empty
# OBSERVABILITY_AUTO_STORE=false

# LangSmith
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=agent-jumbo
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Langfuse
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# MOS INTEGRATION (Linear / Motion / Notion)
# ============================================
# LINEAR_API_KEY=lin_api_xxxxx
# LINEAR_DEFAULT_TEAM_ID=
# MOTION_API_KEY=
# NOTION_API_KEY=secret_xxxxx
# NOTION_DEFAULT_DATABASE_ID=

# ============================================
# TELEMETRY
# ============================================
# TELEMETRY_ENABLED=false
# TELEMETRY_MAX_EVENTS=1000

# ============================================
# CLAUDE CODE INTEGRATION
# ============================================
# Route AI operations through local Claude Code CLI
# DEPLOYMENT_MODE=local                    # local, docker, or cloud
#   - local:  Uses Claude Max plan with OAuth (interactive)
#   - docker: Automated container deployment with --dangerously-skip-permissions
#   - cloud:  Cloud deployment, falls back to API keys

# CLAUDE_CODE_ENABLED=true
# CLAUDE_CODE_CLI_PATH=claude              # Path to claude CLI binary
# CLAUDE_CODE_DEFAULT_MODEL=sonnet-4-5    # Default model (sonnet-4-5, opus-4-5)
# CLAUDE_CODE_AUTH_CHECK_INTERVAL=3600    # Check auth every hour (seconds)
# CLAUDE_CODE_SKIP_PERMISSIONS=false      # Set to true for Docker automated deployments
# CLAUDE_CODE_FALLBACK_TO_API=false       # Fallback to API if CLI fails

# Authentication (choose ONE method)
# Method 1: Environment variable (recommended for newer Claude Code CLI)
# CLAUDE_CODE_OAUTH_TOKEN=<your-token>    # Get token from: claude setup-token

# Method 2: OAuth Session Management (for file-based auth, local mode only)
# CLAUDE_CODE_AUTO_REAUTH=false           # Auto-trigger re-auth (requires user interaction)
# CLAUDE_CODE_SESSION_WARNING_THRESHOLD=300  # Warn 5 min before session expires (seconds)

# ============================================
# BASELINE MODEL CONFIGURATION
# ============================================
# Qwen 2.5 3B as baseline (always-available fallback)
BASELINE_MODEL_ENABLED=true
BASELINE_MODEL_PROVIDER=ollama
BASELINE_MODEL_NAME=qwen2.5-coder:3b
BASELINE_AUTO_PULL=true              # Auto-pull if not available
BASELINE_FALLBACK_CHAIN=qwen2.5-coder:7b,gpt-4o-mini

# ============================================
# OPENCODE INTEGRATION
# ============================================
OPENCODE_ENABLED=true
OPENCODE_MODEL_PROVIDER=ollama
OPENCODE_MODEL_NAME=qwen2.5-coder:7b
OPENCODE_API_BASE=http://localhost:11434

# ============================================
# DEVELOPMENT
# ============================================
# UPDATE_CHECK_ENABLED=true
# LITELLM_LOG=ERROR                 # ERROR, WARNING, INFO, DEBUG
# LITELLM_LOCAL_MODEL_COST_MAP=True # Use bundled model pricing data instead of fetching remote map at startup

# ============================================
# STRIPE INTEGRATION
# ============================================
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CHECKOUT_SUCCESS_URL=https://your-domain.com/success
# STRIPE_CHECKOUT_CANCEL_URL=https://your-domain.com/cancel

# ============================================
# TELEGRAM DELIVERY
# ============================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ALERT_CHAT_ID=

# ============================================
# MAHOOSUC OS INTEGRATION
# ============================================
# Imported 414 commands, 21 agents, 5 skills from Mahoosuc Operating System
# Location: .claude/ directory

# Command Access
MAHOOSUC_COMMANDS_DIR=.claude/commands
MAHOOSUC_AGENTS_DIR=.claude/agents
MAHOOSUC_SKILLS_DIR=.claude/skills

# Integration Mode
# Options: reference, mcp-bridge, native-tools
# - reference: Use as documentation/patterns only (default)
# - mcp-bridge: Execute commands via Claude Code MCP (requires CLAUDE_CODE_ENABLED=true)
# - native-tools: Convert to Agent Jumbo tools (manual conversion required)
MAHOOSUC_INTEGRATION_MODE=reference

# Command Execution (if using mcp-bridge mode)
# MAHOOSUC_COMMAND_TIMEOUT=300           # Command timeout in seconds
# MAHOOSUC_AUTO_APPROVE=false            # Auto-approve command execution (USE WITH CAUTION)

# Agent Routing (if adapted to Agent Jumbo)
# MAHOOSUC_ENABLE_AGENT_ROUTING=false    # Enable Mahoosuc agent routing intelligence
# MAHOOSUC_AGENT_FALLBACK=master-orchestrator  # Fallback agent for routing failures

# Skill Conversion (if converting skills to tools)
# MAHOOSUC_SKILL_PREFIX=mahoosuc_        # Prefix for converted skill tools

# Performance Monitoring
# MAHOOSUC_TRACK_USAGE=false             # Track command/agent usage metrics
# MAHOOSUC_LOG_EXECUTIONS=false          # Log all Mahoosuc command executions

# Documentation
# See: .claude/docs/IMPORT_SUMMARY.md
# See: .claude/docs/USING_MAHOOSUC_COMMANDS.md
# See: .claude/docs/AGENT_JUMBO_INTEGRATION.md
